# Copy to .env and adjust for your environment: cp .env.example .env
# docker-compose reads these automatically.

# Django
DEBUG=False
SECRET_KEY=please-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Postgres
POSTGRES_DB=bookshop
POSTGRES_USER=bookshop
POSTGRES_PASSWORD=bookshop

# Seed demo data (books, covers, demo user, orders) on first backend boot.
SEED_ON_START=1
